programa 
{
  //Controle de Notas - Secretaria Escolar
  //Desenvolvedora: Lorena Galvão Batista

  //Declaração das Variáveis e Vetores
  cadeia aluno[99], resultado[99]
  real nota1, nota2, media[99]
  inteiro quantidadeAlunos

  // Função para o Cálculo das Médias e Resultado Final

  funcao real calcularMedia (real n1, real n2)
  {
    retorne (n1+n2)/2
  }

  // Função para Verificação do Status de Aprovação (Aprovado ou Reprovado)

  funcao cadeia notaFinal ( real media)
  {
    se (media >= 5)
    {
      retorne ("APROVADO")
    }
    senao
    {
      retorne ("REPROVADO")
    }
  }

  funcao inicio() 
  {

    escreva("*** SECRETARIA ESCOLAR ***\n")
    escreva("\n") 

  // Entrada dos Dados e Estrutura de Repetição
    
    escreva("Digite a quantidade de alunos(as): ")
    leia(quantidadeAlunos)
    escreva("\n")
    
    para (inteiro i = 0; i < quantidadeAlunos; i++)
    {
    escreva("Digite o nome do aluno ", i+1, ": ")
    leia(aluno[i])
    escreva("Digite a 1ª nota de ", aluno[i], ": ")
    leia(nota1)
    escreva("Digite a 2ª nota de ", aluno[i], ": ")
    leia(nota2)
    escreva("\n")

    media[i] = calcularMedia (nota1, nota2)
    }

  // Verificação das Notas 

    escreva("*** RESULTADOS FINAIS ***\n")
    escreva("\n")
    
    para (inteiro i = 0; i < quantidadeAlunos; i++)
    {
    resultado[i] = notaFinal (media[i])
      escreva("Aluno(a): ", aluno[i], " | Média: ", media[i], " | Resultado: ", resultado[i], "\n")
    }
    } 
  }
