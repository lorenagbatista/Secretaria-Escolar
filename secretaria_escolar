programa 
{

  //Controle de Notas - Secretaria Escolar
  //Desenvolvedora: Lorena Galvão Batista

  //Declaração de Vetores
  //O sistema foi pensado para a avaliação do resultado escolar dos alunos individualmente e por turma, considerando turmas de até 45 alunos. Por isso, os vetores foram criados com possibilidade para 45 variáveis, considerando que as variáveis em [0] não serão utilizadas, partindo, então, de [1].
  cadeia aluno[99], resultado[99]
  real media[99]

  //Declaração de variáveis
  inteiro quantidadeAlunos
  real nota1, nota2, somaMedias = 0, mediaGeral
  cadeia turma

  //Função para o Cálculo das Médias

  funcao real calcularMedia (real n1, real n2)
  {
    retorne (n1+n2)/2
  }

  //Função para Verificação do Status de Aprovação (Aprovado ou Reprovado)

  funcao cadeia notaFinal ( real media)
  {
    se (media >= 5)
    {
      retorne ("APROVADO")
    }
    senao
    {
      retorne ("REPROVADO")
    }
  }

  funcao inicio() 
  {

    escreva("*** SECRETARIA ESCOLAR ***\n")
    escreva("\n") 

  //Entrada dos Dados e Estrutura de Repetição
  //Aqui será definido pelo usuário a quantidade de alunos, fazendo com que os sistema se repita até a quantidade informada, relacionando e salvando as notas à veriável dentro do vetor aluno[i].
  //O sistema continuará rodando enquanto o contador i for menor que a quantidade de alunos. A cada repetição, "i" é acrescido de 1.
  //Ao final, foi criada uma fórmula para obter a soma das médias totais, com o objetivo de obter um indicador de média geral da turma ao final do programa. Foi atrubuido o valor inicial "0" para a variável "somaMedias" e, a cada repetição, a média calculada por aluno é somada à variáve.

    escreva("Digite o ano e a turma: ")
    leia(turma)
    escreva("\n")
    escreva("Digite a quantidade de alunos(as): ")
    leia(quantidadeAlunos)
    escreva("\n")
    
    para (inteiro i = 0; i < quantidadeAlunos; i++)
    {
    escreva("Digite o nome do aluno ", i+1, ": ")
    leia(aluno[i])
    escreva("Digite a 1ª nota de ", aluno[i], ": ")
    leia(nota1)
    escreva("Digite a 2ª nota de ", aluno[i], ": ")
    leia(nota2)
    escreva("\n")

    media[i] = calcularMedia (nota1, nota2)
    somaMedias = somaMedias + media[i]
    }

  // Verificação das Notas 

    escreva("*** RESULTADOS FINAIS ***\n")
    escreva("\n")
    
    para (inteiro i = 0; i < quantidadeAlunos; i++)
    {
    resultado[i] = notaFinal (media[i])
      escreva("Aluno(a): ", aluno[i], " | Média: ", media[i], " | Resultado: ", resultado[i], "\n")
    }

    escreva("\n")
    mediaGeral = somaMedias / quantidadeAlunos
    escreva("A MÉDIA GERAL DA TURMA ", turma, " foi ", mediaGeral, "\n")

    } 
  }
